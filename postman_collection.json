{
	"info": {
		"name": "OpenJarvis Backend API",
		"description": "OpenJarvis 后端 API 接口测试集合",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "12345"
	},
	"item": [
		{
			"name": "RSS订阅源管理",
			"item": [
				{
					"name": "获取订阅源列表",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/feed/list",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "feed", "list"]
						},
						"description": "获取所有活跃的 RSS 订阅源列表"
					},
					"response": []
				},
				{
					"name": "添加订阅源",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Hacker News\",\n  \"url\": \"https://hnrss.org/frontpage\",\n  \"pushCount\": 10\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/feed/create",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "feed", "create"]
						},
						"description": "添加新的 RSS 订阅源"
					},
					"response": []
				},
				{
					"name": "修改订阅源",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Hacker News - 更新\",\n  \"pushCount\": 15\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/feed/update/{{feedId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "feed", "update", "{{feedId}}"]
						},
						"description": "修改指定的 RSS 订阅源"
					},
					"response": []
				},
				{
					"name": "删除订阅源",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/feed/delete/{{feedId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "feed", "delete", "{{feedId}}"]
						},
						"description": "删除指定的 RSS 订阅源（软删除）"
					},
					"response": []
				}
			]
		},
		{
			"name": "全局配置管理",
			"item": [
				{
					"name": "获取全局配置",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/config/global",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "config", "global"]
						},
						"description": "获取全局配置（RSS定时时间和AI翻译开关）"
					},
					"response": []
				},
				{
					"name": "更新全局配置",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"rssSchedule\": \"0 10 * * *\",\n  \"translationEnabled\": false\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/config/global",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "config", "global"]
						},
						"description": "更新全局配置（RSS定时时间和AI翻译开关）"
					},
					"response": []
				}
			]
		},
		{
			"name": "文章推送",
			"item": [
				{
					"name": "获取今日推送",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/article/today",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "article", "today"]
						},
						"description": "获取今日推送的所有文章"
					},
					"response": []
				},
			{
				"name": "获取今日推送（按领域过滤）",
				"request": {
					"method": "GET",
					"header": [],
					"url": {
						"raw": "{{baseUrl}}/api/v1/article/today?domain_id={{domainId}}",
						"host": ["{{baseUrl}}"],
						"path": ["api", "v1", "article", "today"],
						"query": [
							{
								"key": "domain_id",
								"value": "{{domainId}}",
								"description": "关键领域ID (可选)"
							},
							{
								"key": "keywords",
								"value": "AI,机器学习",
								"description": "正向关键词，逗号分隔 (可选)",
								"disabled": true
							},
							{
								"key": "exclude_keywords",
								"value": "股价,融资",
								"description": "负向关键词，逗号分隔 (可选)",
								"disabled": true
							},
							{
								"key": "apply_filter",
								"value": "true",
								"description": "是否应用默认过滤规则 (可选, 默认true)",
								"disabled": true
							}
						]
					},
					"description": "获取今日推送，支持按关键领域和关键词过滤。响应包含 isNew（今日新增标签）、usedFallback、queryMethod、filterTier 等诊断信息"
				},
				"response": []
			},
			{
				"name": "今日推送诊断",
				"request": {
					"method": "GET",
					"header": [],
					"url": {
						"raw": "{{baseUrl}}/api/v1/article/today/debug",
						"host": ["{{baseUrl}}"],
						"path": ["api", "v1", "article", "today", "debug"]
					},
					"description": "诊断 /today 接口为什么没有返回文章，返回系统时间、各查询策略命中数、来源统计、过滤域配置等信息"
				},
				"response": []
			},
				{
					"name": "获取历史推送",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/article/history?page=1&pageSize=20",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "article", "history"],
							"query": [
								{
									"key": "page",
									"value": "1",
									"description": "页码"
								},
								{
									"key": "pageSize",
									"value": "20",
									"description": "每页数量"
								},
								{
									"key": "date",
									"value": "2026-02-15",
									"description": "日期筛选 (可选)",
									"disabled": true
								},
								{
									"key": "domain_id",
									"value": "{{domainId}}",
									"description": "关键领域ID (可选)",
									"disabled": true
								},
								{
									"key": "keywords",
									"value": "AI,机器学习",
									"description": "正向关键词，逗号分隔 (可选)",
									"disabled": true
								},
								{
									"key": "exclude_keywords",
									"value": "股价,融资",
									"description": "负向关键词，逗号分隔 (可选)",
									"disabled": true
								}
							]
						},
						"description": "获取历史推送文章，支持分页、日期筛选和过滤"
					},
					"response": []
				},
				{
					"name": "标记文章已读",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/article/mark-read/{{articleId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "article", "mark-read", "{{articleId}}"]
						},
						"description": "标记指定文章为已读"
					},
					"response": []
				}
			]
		},
		{
			"name": "AI功能",
			"item": [
				{
					"name": "生成选题",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"count\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/ai/generate-ideas",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "ai", "generate-ideas"]
						},
						"description": "基于最新文章生成 AI 博客选题"
					},
					"response": []
				},
				{
					"name": "生成选题（指定文章）",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"articleIds\": [1, 2, 3, 4, 5],\n  \"count\": 5\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/ai/generate-ideas",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "ai", "generate-ideas"]
						},
						"description": "基于指定文章 ID 生成 AI 博客选题"
					},
					"response": []
				},
				{
					"name": "生成文章",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"ideaId\": \"idea_1\",\n  \"ideaTitle\": \"如何使用 AI 提升开发效率\",\n  \"style\": \"技术教程\",\n  \"audience\": \"技术从业者\",\n  \"length\": \"medium\",\n  \"language\": \"zh-CN\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/ai/generate-article",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "ai", "generate-article"]
						},
						"description": "基于选题生成完整文章"
					},
					"response": []
				}
			]
		},
		{
			"name": "文章过滤",
			"item": [
				{
					"name": "获取关键领域列表",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/domains",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "domains"],
							"query": [
								{
									"key": "enabled",
									"value": "true",
									"description": "是否启用 (可选)",
									"disabled": true
								}
							]
						},
						"description": "获取所有关键领域列表"
					},
					"response": []
				},
				{
					"name": "创建关键领域",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"AI模型架构与算法创新\",\n  \"description\": \"AI模型架构与算法创新相关领域\",\n  \"enabled\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/domains",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "domains"]
						},
						"description": "创建新的关键领域"
					},
					"response": []
				},
				{
					"name": "更新关键领域",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"AI模型架构与算法创新（更新）\",\n  \"description\": \"更新后的描述\",\n  \"enabled\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/domains/{{domainId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "domains", "{{domainId}}"]
						},
						"description": "更新指定的关键领域"
					},
					"response": []
				},
				{
					"name": "删除关键领域",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/domains/{{domainId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "domains", "{{domainId}}"]
						},
						"description": "删除指定的关键领域（会级联删除该领域下的所有关键词）"
					},
					"response": []
				},
				{
					"name": "获取关键词列表",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/keywords?domain_id={{domainId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "keywords"],
							"query": [
								{
									"key": "domain_id",
									"value": "{{domainId}}",
									"description": "领域ID (可选)"
								},
								{
									"key": "keyword_type",
									"value": "positive",
									"description": "关键词类型: positive/negative (可选)",
									"disabled": true
								}
							]
						},
						"description": "获取关键词列表，可按领域和类型筛选"
					},
					"response": []
				},
				{
					"name": "创建关键词",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"domain_id\": 1,\n  \"keyword_type\": \"positive\",\n  \"keyword_text\": \"/AI|人工智能|机器学习/\",\n  \"is_regex\": true,\n  \"is_required\": false,\n  \"alias\": \"AI相关\",\n  \"priority\": 0,\n  \"max_results\": null\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/keywords",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "keywords"]
						},
						"description": "创建新的关键词规则\n\n- keyword_type: positive(正向) 或 negative(负向/过滤词)\n- is_regex: 是否为正则表达式（正则表达式需用 /.../ 包裹）\n- is_required: 是否为必须词（+前缀）\n- max_results: 限制该关键词组最多显示多少条（@N）"
					},
					"response": []
				},
				{
					"name": "删除关键词",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/filter/keywords/{{keywordId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "filter", "keywords", "{{keywordId}}"]
						},
						"description": "删除指定的关键词"
					},
					"response": []
				}
			]
		},
		{
			"name": "健康检查",
			"item": [
				{
					"name": "Root Endpoint",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/",
							"host": ["{{baseUrl}}"],
							"path": [""]
						},
						"description": "根路径健康检查"
					},
					"response": []
				},
				{
					"name": "API Docs",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/docs",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "docs"]
						},
						"description": "API 文档（Swagger UI）"
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:12135",
			"type": "string"
		},
		{
			"key": "feedId",
			"value": "feed_12345678",
			"type": "string",
			"description": "示例订阅源 ID，执行添加订阅源后替换为实际 ID"
		},
		{
			"key": "articleId",
			"value": "1",
			"type": "string",
			"description": "示例文章 ID，查看今日推送后替换为实际 ID"
		},
		{
			"key": "domainId",
			"value": "1",
			"type": "string",
			"description": "示例关键领域 ID，获取领域列表后替换为实际 ID"
		},
		{
			"key": "keywordId",
			"value": "1",
			"type": "string",
			"description": "示例关键词 ID，获取关键词列表后替换为实际 ID"
		}
	]
}

