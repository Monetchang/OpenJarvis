# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openjarvis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# AI 配置
AI_API_KEY=your_api_key_here
AI_MODEL=deepseek/deepseek-chat
AI_API_BASE=https://api.deepseek.com
AI_TEMPERATURE=1.0
AI_MAX_TOKENS=5000
AI_TIMEOUT=120

# 翻译配置（mt=免费机器翻译, ai=LLM翻译）
TRANSLATION_PROVIDER=mt
TRANSLATION_ENABLED=true
TRANSLATION_LANGUAGE=Chinese

# 选题配置
TOPICS_ENABLED=true
TOPICS_MIN_COUNT=3
TOPICS_MAX_COUNT=10

# RSS 配置
RSS_REQUEST_INTERVAL=2000
RSS_MAX_CONCURRENT=8

# HTTP 超时与重试（同时作用于 RSS 抓取和 fetch_url）
RSS_HTTP_CONNECT_TIMEOUT=10
RSS_HTTP_READ_TIMEOUT=15
RSS_HTTP_RETRIES=1

# 代理（http://、https://、socks5h:// 均支持）
# socks5h 让 DNS 也走代理，适合无法直连的国内环境（medium.com 等）
RSS_USE_PROXY=false
RSS_PROXY_URL=
RSS_PROXY_HTTPS_URL=
RSS_NO_PROXY=

TIMEZONE=Asia/Shanghai

# 用户/邀请码（邮箱绑定时校验）
INVITE_CODES=DEMO2024,TEST2024

# 推送测试模式（仅抓 1 个源、跳过选题，节省时间）
PUSH_TEST_MODE=false

# 邮件推送（二选一）
# 方式1：Resend，仅需 API Key，免 SMTP 配置，免费 100 封/天
RESEND_API_KEY=re_xxx
RESEND_FROM=OpenJarvis <onboarding@resend.dev>
# 方式2：自建 SMTP
# SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASSWORD= SMTP_FROM= SMTP_USE_TLS=true

# Feishu 配置（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
